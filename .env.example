# --- BCV Scraper config ------------------------------------------------

# BCV page to scrape (default: official home).
BCV_URL=https://www.bcv.org.ve/

# Shared secret required by POST /api/scrape.
# Leave empty to disable the manual-trigger endpoint entirely.
SCRAPE_API_KEY=

# Timezone for the scheduler and the dates shown in the UI.
TZ=America/Caracas

# Comma-separated list of hours (0-23) when the scraper runs.
# Default = 6 times a day, every 4 hours.
SCRAPE_HOURS=0,4,8,12,16,20

# Run an extra scrape as soon as the service starts.
# Set to false to skip the startup scrape (only the cron schedule will run).
BCV_SCRAPE_ON_STARTUP=true

# HTTP timeout (seconds) for the BCV request.
BCV_HTTP_TIMEOUT=15

# Override the user-agent if BCV blocks the default.
# BCV_USER_AGENT=Mozilla/5.0 …

# SSL verification for the BCV request.
# Set BCV_VERIFY_SSL=false ONLY in dev environments that lack a CA bundle
# (e.g. minimal Python builds). Production should keep it on.
BCV_VERIFY_SSL=true

# Optional path to a custom CA bundle (e.g. corporate proxy).
# BCV_SSL_BUNDLE=/etc/ssl/certs/ca-certificates.crt

# Server bind address / port.
BCV_HOST=127.0.0.1
BCV_PORT=8000
